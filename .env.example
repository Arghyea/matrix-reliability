# ─────────────────────────────────────────────────────────────────────
# Matrix Forex — environment variables
# Copy this file to ".env.local" for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# ─────────────────────────────────────────────────────────────────────

# WHERE LEADS GO. Every form submission is emailed here. One address.
LEAD_TO_EMAIL=leads@matrixforex.in

# The "from" address. With Resend you must verify your sending domain
# first (resend.com/domains). Until then you can use onboarding@resend.dev.
LEAD_FROM_EMAIL="Matrix Forex Website <onboarding@resend.dev>"

# Resend API key — get one free at resend.com (sign up, create an API key).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Public site URL (used for canonical tags / sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://matrixforex.in

# ── OPTIONAL: Cloudflare Turnstile (free, invisible bot protection) ──
# Leave both blank to disable. If set, the lead form is verified server-side.
# Get keys at dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Rate limiting (Upstash Redis — free tier) ──
# Throttles lead submissions per IP (5 per 10 min). Without these, a weak
# in-memory fallback is used (fine for local dev, not for production).
# Create a free Redis DB at upstash.com → copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
